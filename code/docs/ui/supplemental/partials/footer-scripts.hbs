{{#if (or site.url siteRootPath)}}
<script id="site-script" src="{{{or site.url siteRootPath}}}/_/js/site.js" data-ui-root-path="{{{or site.url siteRootPath}}}/_/"></script>
<script async src="{{{or site.url siteRootPath}}}/_/js/vendor/highlight.js"></script>
{{else}}
<script id="site-script" src="{{{uiRootPath}}}/js/site.js" data-ui-root-path="{{{uiRootPath}}}"></script>
<script async src="{{{uiRootPath}}}/js/vendor/highlight.js"></script>
{{/if}}
