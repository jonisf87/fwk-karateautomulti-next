<link rel="stylesheet" href="{{{uiRootPath}}}/css/site.css">
<style>
:root{--docs-bg:#0d1117;--docs-surface:#161b22;--docs-surface-2:#21262d;--docs-border:#30363d;--docs-border-soft:#484f58;--docs-text:#e6edf3;--docs-muted:#8b949e;--docs-link:#58a6ff;--docs-link-hover:#79c0ff;--docs-shadow:0 14px 30px rgba(1,4,9,.28);--docs-font:Inter,"Segoe UI",Roboto,sans-serif}
html,body{background:var(--docs-bg)}
body{font-family:var(--docs-font);color:var(--docs-text)}
a{color:var(--docs-link)}
a:hover{color:var(--docs-link-hover)}
strong,b,.doc strong,.doc b{color:#f8fafc;font-weight:700}
.edit-this-page{display:none!important}

.header,.navbar{background:var(--docs-bg)!important;border-bottom:1px solid var(--docs-border)!important}
.navbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:0 .75rem}
.navbar-item,.navbar-link{color:var(--docs-text)!important}
.navbar-item:hover,.navbar-link:hover{background:rgba(88,166,255,.08);color:#fff}
.brand-mark{gap:.65rem;font-weight:700;letter-spacing:0}
.brand-icon{color:var(--docs-link)}
.nav-github{border:1px solid var(--docs-border-soft);border-radius:999px;padding:.35rem .75rem!important;line-height:1.2;white-space:nowrap}

.body,.nav-container,.nav,.article,.toolbar,.doc,.toc.sidebar{background:transparent}
.toolbar{background:var(--docs-surface);border-bottom:1px solid var(--docs-border)}
.breadcrumbs a,.toolbar .home-link{color:var(--docs-muted)}
.breadcrumbs a:hover{color:#fff}
.toolbar .nav-toggle,.toolbar .home-link{color:var(--docs-text)!important;opacity:1!important;filter:brightness(0) saturate(100%) invert(92%) sepia(13%) saturate(224%) hue-rotate(176deg) brightness(101%) contrast(92%)}
.toolbar .nav-toggle:hover,.toolbar .home-link:hover{filter:brightness(0) saturate(100%) invert(100%)}

.nav-panel-menu,.nav-panel-explore,.toc.sidebar,.toc.sidebar .toc-menu{background:var(--docs-surface-2)!important;border-color:var(--docs-border)!important;box-shadow:none!important}
.nav-menu .title a,.nav-menu h3.title a{color:var(--docs-text)!important;font-weight:700!important;opacity:1!important}
.nav-menu .title,.nav-menu h3.title{color:var(--docs-text)!important;opacity:1!important}
.toc.sidebar{display:none!important;background:var(--docs-surface-2)!important;padding:0 1rem 0 0!important}
.toc.sidebar::before,.toc.sidebar .toc-menu h3{color:var(--docs-text)!important;font-weight:700!important;opacity:1!important;font-size:1rem!important;letter-spacing:0!important}
.toc.sidebar .toc-menu{position:static!important;top:auto!important;margin-right:0!important;padding:1rem 0 1rem 1rem!important;min-height:100%}
.toc.sidebar .toc-menu ul{max-height:none!important;overflow:visible!important}
.toc.sidebar .toc-menu ul,.toc.sidebar .toc-menu li,.toc.sidebar .toc-menu a{border-left:none!important;box-shadow:none!important}
.toc.sidebar .toc-menu a{padding-left:0!important;color:var(--docs-text)!important;opacity:.92!important}
.toc.sidebar .toc-menu a:hover{color:#fff!important}
.toc.sidebar .toc-menu .is-current-toc-node>a,.toc.sidebar .toc-menu .is-active>a{color:#fff!important;font-weight:600!important}
.nav-list a,.nav-panel-explore .context a,.toc.sidebar a{color:var(--docs-muted)}
.nav-list a.is-current-page,.nav-list a:hover,.toc.sidebar a:hover{color:#fff}
.nav-item-toggle::before{filter:brightness(1.35)}
.nav,.nav-container,.nav-panel-menu,.nav-panel-explore{scrollbar-width:none}
.nav::-webkit-scrollbar,.nav-container::-webkit-scrollbar,.nav-panel-menu::-webkit-scrollbar,.nav-panel-explore::-webkit-scrollbar{display:none;width:0;height:0}

.doc{color:var(--docs-text)}
.doc>h1.page{margin-top:1rem}
.doc h1,.doc h2,.doc h3,.doc h4{color:#f8fafc}
.doc p,.doc li,.doc td,.doc th{color:var(--docs-muted)}
.doc code{background:#f8fafc;color:#111827;border-radius:4px;padding:.1rem .35rem}
.doc .listingblock>.content,.doc .literalblock>.content{background:var(--docs-bg);border:1px solid var(--docs-border);border-radius:10px}
.doc table.tableblock{background:var(--docs-surface);border-color:var(--docs-border)}

.doc .sidebarblock.home-hero{margin:0 0 2rem;background:linear-gradient(180deg,rgba(88,166,255,.08),rgba(88,166,255,0) 45%),var(--docs-surface-2);border:1px solid var(--docs-border);border-radius:18px;box-shadow:var(--docs-shadow)}
.doc .sidebarblock.home-hero>.content{color:var(--docs-text)}
.doc .sidebarblock.home-hero p{color:var(--docs-muted)}
.eyebrow{display:inline-block;margin-bottom:.6rem;color:var(--docs-link);font-size:.82rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700}
.hero-title{display:block;margin:.2rem 0 0;color:#f8fafc;font-size:clamp(2rem,4vw,3.1rem);font-weight:800;line-height:1.05}
.hero-actions{margin-top:1.5rem}
.hero-actions ul{display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-start;padding-left:0;list-style:none}
.hero-actions ul>li{margin:0!important}
.hero-actions ul>li+li{margin-top:0!important}
.hero-actions li>p{margin:0!important}
.hero-actions a{display:inline-flex;align-items:center;padding:.75rem 1rem;border:1px solid var(--docs-border-soft);border-radius:999px;color:var(--docs-text);text-decoration:none;line-height:1.2;background:rgba(88,166,255,.08)}
.hero-actions a:hover{background:rgba(88,166,255,.16);color:#fff}

.doc .ulist.home-card-grid{margin:0 0 2rem}
.doc .ulist.home-card-grid>ul{display:grid;gap:1rem;padding-left:0;list-style:none}
.doc .ulist.home-card-grid>ul>li{margin:0;padding:1.25rem;border:1px solid var(--docs-border);border-radius:14px;background:var(--docs-surface-2);box-shadow:var(--docs-shadow)}
.home-card-title{display:block;margin-bottom:.75rem;color:#f8fafc;font-size:1.08rem;font-weight:700}

.footer{background:var(--docs-surface)!important;border-top:1px solid var(--docs-border)!important}
.footer,.footer *{color:#e5e7eb!important}
.footer a{color:var(--docs-link)!important}
.footer a:hover{color:#fff!important}
.footer-simple{display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap}

@media screen and (min-width:1024px){
  main>.content{display:grid!important;grid-template-columns:minmax(0,1fr) 16rem!important;align-items:start!important}
  .toc.sidebar{display:block!important}
  main>.content>.toc.sidebar{grid-column:2}
  main>.content>article.doc{grid-column:1;max-width:none!important;min-width:0}
  .doc .ulist.home-card-grid>ul{grid-template-columns:repeat(2,minmax(0,1fr))}
}
@media screen and (max-width:768px){
  .navbar{padding:0 .5rem}
  .brand-mark{padding-left:.25rem}
  .brand-mark span:last-child{font-size:1rem;line-height:1.15}
  .nav-github{display:none!important}
  .footer-simple{flex-direction:column;align-items:flex-start}
}
</style>
